generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(200)
  code      String   @unique @db.VarChar(50)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  enrollmentApplications EnrollmentApplication[]
  crmLeads               CrmLead[]

  @@map("schools")
}

model EnrollmentApplication {
  id              String   @id @default(uuid()) @db.Uuid
  schoolId        String   @map("school_id") @db.Uuid
  applicationCode String   @map("application_code") @db.VarChar(50)
  studentFirstName String  @map("student_first_name") @db.VarChar(100)
  studentLastName  String  @map("student_last_name") @db.VarChar(100)
  dateOfBirth     DateTime? @map("date_of_birth") @db.Date
  gender          String?  @db.VarChar(10)
  parentName      String   @map("parent_name") @db.VarChar(255)
  parentPhone     String   @map("parent_phone") @db.VarChar(20)
  parentEmail     String?  @map("parent_email") @db.VarChar(255)
  address         String?  @db.Text
  previousSchool  String?  @map("previous_school") @db.VarChar(255)
  gradeApplying   Int      @map("grade_level_applying")
  documents       Json?    @default("[]")
  status          String   @default("submitted") @db.VarChar(30)
  notes           String?  @db.Text
  source          String?  @db.VarChar(50)
  reviewedBy      String?  @map("reviewed_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, applicationCode])
  @@map("enrollment_applications")
}

model CrmLead {
  id             String   @id @default(uuid()) @db.Uuid
  schoolId       String   @map("school_id") @db.Uuid
  parentName     String   @map("parent_name") @db.VarChar(255)
  phone          String   @db.VarChar(20)
  email          String?  @db.VarChar(255)
  studentName    String?  @map("student_name") @db.VarChar(255)
  gradeInterest  Int?     @map("grade_interest")
  source         String?  @db.VarChar(50)
  status         String   @default("new") @db.VarChar(30)
  assignedTo     String?  @map("assigned_to") @db.Uuid
  lastContactDate DateTime? @map("last_contact_date") @db.Date
  notes          String?  @db.Text
  tags           String[] @default([])
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id])

  @@map("crm_leads")
}
