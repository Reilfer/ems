generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(200)
  code      String   @unique @db.VarChar(50)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  teachers    Teacher[]
  timekeeping Timekeeping[]
  payrolls    Payroll[]
  contracts   Contract[]
  users       User[]

  @@map("schools")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  schoolId     String    @map("school_id") @db.Uuid
  email        String    @db.VarChar(255)
  firstName    String    @map("first_name") @db.VarChar(100)
  lastName     String    @map("last_name") @db.VarChar(100)
  phone        String?   @db.VarChar(20)
  role         String    @default("TEACHER") @db.VarChar(50)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  school      School        @relation(fields: [schoolId], references: [id])
  timekeeping Timekeeping[]
  payrolls    Payroll[]
  contracts   Contract[]

  @@unique([schoolId, email])
  @@map("users")
}

model Teacher {
  id             String   @id @default(uuid()) @db.Uuid
  schoolId       String   @map("school_id") @db.Uuid
  employeeCode   String   @map("employee_code") @db.VarChar(20)
  firstName      String   @map("first_name") @db.VarChar(100)
  lastName       String   @map("last_name") @db.VarChar(100)
  email          String?  @db.VarChar(255)
  phone          String?  @db.VarChar(20)
  specialization String?  @db.VarChar(255)
  qualification  String?  @db.VarChar(255)
  department     String?  @db.VarChar(100)
  hireDate       DateTime? @map("hire_date") @db.Date
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, employeeCode])
  @@map("teachers")
}

model Timekeeping {
  id        String    @id @default(uuid()) @db.Uuid
  schoolId  String    @map("school_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  date      DateTime  @db.Date
  checkIn   DateTime? @map("check_in")
  checkOut  DateTime? @map("check_out")
  method    String    @default("manual") @db.VarChar(20)
  status    String    @default("PRESENT") @db.VarChar(20)
  workHours Float?    @map("work_hours")
  note      String?   @db.Text
  createdAt DateTime  @default(now()) @map("created_at")

  school School @relation(fields: [schoolId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@map("timekeeping")
}

model Payroll {
  id           String   @id @default(uuid()) @db.Uuid
  schoolId     String   @map("school_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  year         Int
  month        Int
  baseSalary   Decimal  @map("base_salary") @db.Decimal(15, 2)
  allowances   Decimal  @default(0) @db.Decimal(15, 2)
  deductions   Decimal  @default(0) @db.Decimal(15, 2)
  overtimePay  Decimal  @default(0) @map("overtime_pay") @db.Decimal(15, 2)
  insurance    Decimal  @default(0) @db.Decimal(15, 2)
  tax          Decimal  @default(0) @db.Decimal(15, 2)
  netSalary    Decimal  @map("net_salary") @db.Decimal(15, 2)
  workDays     Int      @default(0) @map("work_days")
  absentDays   Int      @default(0) @map("absent_days")
  status       String   @default("DRAFT") @db.VarChar(20)
  paidAt       DateTime? @map("paid_at")
  details      Json?    @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, month, year])
  @@map("payroll")
}

model Contract {
  id             String    @id @default(uuid()) @db.Uuid
  schoolId       String    @map("school_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  contractNumber String    @map("contract_number") @db.VarChar(50)
  type           String    @db.VarChar(50)
  startDate      DateTime  @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  baseSalary     Decimal   @map("base_salary") @db.Decimal(15, 2)
  position       String?   @db.VarChar(100)
  department     String?   @db.VarChar(100)
  status         String    @default("ACTIVE") @db.VarChar(20)
  attachmentUrl  String?   @map("attachment_url") @db.VarChar(500)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([schoolId, contractNumber])
  @@map("contracts")
}
